# /opt/kiezfinder-api/.env — Rechte 640 (root:www-data). NIE ins Repo!
PORT=4251
ORIGIN=https://kiezfinder.celox.io
# Google Cloud → OAuth 2.0 Client (Web). Autorisierte Redirect-URI:
#   https://kiezfinder.celox.io/api/auth/google/callback
GOOGLE_CLIENT_ID=…apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=…
# openssl rand -hex 32  — signiert die Session-Cookies
APP_SECRET=…
DATA_DIR=/opt/kiezfinder-api/data
